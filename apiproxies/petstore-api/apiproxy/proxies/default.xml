        <?xml version="1.0" encoding="UTF-8" standalone="yes"?>
        <ProxyEndpoint name="default">
            <PreFlow name="PreFlow">
                <Request>
                        <Step><Name>SA-SpikeArrest</Name></Step>
                <Step><Name>VA-VerifyKey</Name></Step>
                <Step><Name>QU-RateLimit</Name></Step>
                <Step><Name>FC-Security</Name></Step>
                <Step><Name>JS-ThreatProtection</Name></Step>
                <Step><Name>AM-RemoveAuthHeader</Name></Step>
                </Request>
                <Response/>
            </PreFlow>
            <PostFlow name="PostFlow">
                <Request/>
                <Response>
                        <Step><Name>FC-CORS</Name></Step>
                </Response>
            </PostFlow>
            <Flows>
    <Flow name="OptionsPreFlight">
        <Description>CORS preflight</Description>
        <Request/>
        <Response>
            <Step><Name>FC-CORS</Name></Step>
        </Response>
        <Condition>request.verb == "OPTIONS"</Condition>
    </Flow>
</Flows>
            <FaultRules>
        <FaultRule name="InvalidApiKey">
            <Condition>fault.name = "InvalidApiKey" OR fault.name = "FailedToResolveAPIKey"</Condition>
            <Step><Name>RF-InvalidApiKey</Name></Step>
        </FaultRule>
        <FaultRule name="QuotaViolation">
            <Condition>fault.name = "QuotaViolation"</Condition>
            <Step><Name>RF-QuotaViolation</Name></Step>
        </FaultRule>
        <FaultRule name="SpikeArrestViolation">
            <Condition>fault.name = "SpikeArrestViolation"</Condition>
            <Step><Name>RF-SpikeArrestViolation</Name></Step>
        </FaultRule>
    </FaultRules>
    <DefaultFaultRule name="DefaultFault">
        <AlwaysEnforce>true</AlwaysEnforce>
    </DefaultFaultRule>
            <HTTPProxyConnection>
                <BasePath>/petstore/v1</BasePath>
            </HTTPProxyConnection>
            <RouteRule name="NoRoute">
                <Condition>request.verb == "OPTIONS"</Condition>
            </RouteRule>
            <RouteRule name="default">
                <TargetEndpoint>default</TargetEndpoint>
            </RouteRule>
        </ProxyEndpoint>

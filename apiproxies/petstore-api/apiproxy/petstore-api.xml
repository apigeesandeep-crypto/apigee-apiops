<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<APIProxy revision="1" name="petstore-api">
    <DisplayName>petstore-api</DisplayName>
    <Description>Petstore sample API</Description>
    <BasePaths>/petstore/v1</BasePaths>
    <Policies>
        <Policy>SA-SpikeArrest</Policy>
<Policy>VA-VerifyKey</Policy>
<Policy>QU-RateLimit</Policy>
<Policy>FC-Security</Policy>
<Policy>JS-ThreatProtection</Policy>
<Policy>AM-RemoveAuthHeader</Policy>
<Policy>FC-CORS</Policy>
<Policy>RF-InvalidApiKey</Policy>
<Policy>RF-QuotaViolation</Policy>
<Policy>RF-SpikeArrestViolation</Policy>
    </Policies>
    <ProxyEndpoints>
        <ProxyEndpoint>default</ProxyEndpoint>
    </ProxyEndpoints>
    <TargetEndpoints>
        <TargetEndpoint>default</TargetEndpoint>
    </TargetEndpoints>
    <Resources/>
</APIProxy>

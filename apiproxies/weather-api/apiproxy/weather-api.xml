<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<APIProxy revision="1" name="weather-api">
    <DisplayName>weather-api</DisplayName>
    <Description>Open-Meteo weather data</Description>
    <BasePaths>/weather/v1</BasePaths>
    <Policies>
        <Policy>SA-SpikeArrest</Policy>
        <Policy>OA-VerifyAccessToken</Policy>
        <Policy>QU-RateLimit</Policy>
        <Policy>FC-Security</Policy>
        <Policy>AM-RemoveAuthHeader</Policy>
        <Policy>FC-CORS</Policy>
        <Policy>RF-InvalidApiKey</Policy>
        <Policy>RF-QuotaViolation</Policy>
    </Policies>
    <ProxyEndpoints><ProxyEndpoint>default</ProxyEndpoint></ProxyEndpoints>
    <TargetEndpoints><TargetEndpoint>default</TargetEndpoint></TargetEndpoints>
    <Resources/>
</APIProxy>